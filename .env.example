# NEVER commit real credentials. Copy to .env and add your values. .env is gitignored.
# Google OAuth (Sign in with Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
SESSION_SECRET=random-string-for-session-signing
BASE_URL=http://localhost:3000
# For production: BASE_URL=https://connectx.online

# Order notifications (admin)
CONNECTX_ORDER_EMAIL=your@email.com
CONNECTX_ORDER_PHONE=+15551234567

# Twilio (for SMS to users and admin)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# SMTP settings (required for sending email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@email.com
SMTP_PASS=your-app-password
SMTP_FROM=ConnectX <your-sender@email.com>
